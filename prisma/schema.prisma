// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Waitlist {
  id    String @id @default(cuid())
  email String @unique

  createdAt DateTime @default(now())

  @@map("waitlist")
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  onboarding    Onboarding?
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id     String @id @default(cuid())
  token  String
  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())
  expiresIn DateTime
}

model Onboarding {
  id             String                   @id @default(cuid())
  user           User                     @relation(fields: [userId], references: [id])
  userId         String                   @unique
  role           OnboardingRole
  interest       OnboardingInterest
  timeCommitment OnboardingTimeCommitment

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  SUPER_ADMIN
}

enum OnboardingRole {
  student
  self_taught
  junior
  freelancer
  career_switcher
}

enum OnboardingInterest {
  frontend
  backend
  fullstack
  ai
  freelancing
}

enum OnboardingTimeCommitment {
  less_than_5
  five_to_ten
  ten_to_twenty
  more_than_20
}
